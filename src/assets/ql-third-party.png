pageTitle\":\"Lifestyle Blog Template\",\"category\":\"Websites\",\"project_id\":\"65c2f9ed-16cc-427a-af29-7a59108fd09a\",\"url\":\"https://personal-blog-brthrs.lovable.app\",\"subtitle\":\"Launch a professional content platform with advanced filtering, masonry layouts, and full SEO optimization. Brutalist-minimalist design with 66+ components—go live in hours, not weeks.\",\"tagline\":\"Sophisticated blog design\",\"description\":\"This template gives you a complete lifestyle blog with masonry grids, advanced filtering, and SEO optimization that looks professional with no design skills required.\",\"metaTitle\":\"Lifestyle Blog Template | Dark Mode \u0026 Masonry Layouts | Lovable\",\"metaDescription\":\"A professional lifestyle blog template with masonry layouts, dark mode, advanced filtering, and built-in SEO optimisation. Built with React and TypeScript.\",\"subcategory\":\"blog\",\"platform\":\"Web\",\"screenshot\":\"https://assets.lovable.dev/templates/lifestyle-blog-3-screenshot.webp\",\"thumbnail\":\"https://assets.lovable.dev/templates/lifestyle-blog-3-screenshot.webp\",\"previewScreenshot\":\"https://assets.lovable.dev/templates/lifestyle-blog-3-screenshot.webp\",\"author\":{\"username\":\"Shipit by Brthrs\",\"avatar\":\"https://storage.googleapis.com/gpt-engineer-file-uploads/8jp6KAG7qJZgRp4lIs04ZYXqlhL2/shipitlogo.png\"},\"shownOn\":[\"homepage\",\"dashboard-templates\",\"templates\"],\"is_partner_template\":true,\"partner_profile_url\":\"/experts/shipit-by-brthrs\",\"date\":\"2025-12-01T10:00:00.000Z\",\"highlights\":[{\"icon\":\"rocket_launch\",\"title\":\"Launch Your Content Platform Fast\",\"description\":\"Complete blog system ready to customize and deploy, eliminating months of development time\"},{\"icon\":\"stars\",\"title\":\"Professional Editorial Design System\",\"description\":\"Brutalist-minimalist aesthetic with high-contrast layouts that command attention and build credibility\"},{\"icon\":\"explore\",\"title\":\"Built for Discovery and Engagement\",\"description\":\"Advanced filtering, trending blocks, and related posts drive content discovery and reader retention\"},{\"icon\":\"gauge\",\"title\":\"Lightning-Fast Performance Optimized\",\"description\":\"Lazy loading, code splitting, and optimized chunks deliver sub-second load times for better user experience\"},{\"icon\":\"devices\",\"title\":\"Mobile-First Responsive Excellence\",\"description\":\"Pixel-perfect layouts across all devices from mobile to 4K displays with touch-optimized interactions\"},{\"icon\":\"search\",\"title\":\"Search-Optimized Content Architecture\",\"description\":\"Complete meta tags, structured data, and semantic HTML maximize discoverability and organic traffic\"}],\"features\":[{\"title\":\"Featured Hero Sections\",\"description\":\"Full-width image layouts with editorial-style typography create compelling first impressions that showcase your best content and capture reader attention immediately\"},{\"title\":\"Advanced Content Filtering\",\"description\":\"Multi-level category and tag filtering with real-time count updates helps readers discover relevant content while keeping them engaged on your platform\"},{\"title\":\"Masonry Grid Layouts\",\"description\":\"Pinterest-style responsive grid adapts to varying content lengths, creating visually dynamic pages that encourage exploration and increase time on site\"},{\"title\":\"Dark Mode System\",\"description\":\"Sophisticated light and dark themes with system preference detection and smooth CSS variable transitions provide comfortable reading experiences for all users\"},{\"title\":\"Reading Progress Indicators\",\"description\":\"Fixed top bar shows article completion status while table of contents enables quick navigation, improving user experience for long-form content\"},{\"title\":\"Social Sharing Integration\",\"description\":\"One-click sharing to Twitter, Facebook, LinkedIn, and copy link functionality with toast notifications increases content reach and audience growth\"},{\"title\":\"WCAG 2.1 Accessibility\",\"description\":\"Full keyboard navigation, ARIA labels, screen reader optimization, and skip links ensure your content reaches the widest possible audience inclusively\"},{\"title\":\"SEO-Ready Architecture\",\"description\":\"JSON-LD structured data, Open Graph tags, Twitter Cards, and semantic HTML hierarchy maximize search visibility and social media engagement potential\"},{\"title\":\"Performance-Optimized Loading\",\"description\":\"Route-based code splitting, lazy-loaded images, and manual chunk optimization deliver fast load times that reduce bounce rates and improve conversions\"},{\"title\":\"Extensible Component Library\",\"description\":\"49 shadcn/ui components plus 17 custom blog components provide endless customization possibilities without requiring technical expertise or developer resources\"},{\"title\":\"Related Posts Engine\",\"description\":\"Intelligent content recommendations keep readers engaged longer by surfacing relevant articles, increasing page views and building loyal audience relationships\"},{\"title\":\"Typography Scale System\",\"description\":\"Fluid type scaling with DM Sans font family across seven weights ensures exceptional readability and professional appearance on any screen size\"}],\"content\":\"$53\",\"relativePath\":\"lifestyle-blog-3.md\"},{\"slug\":\"ecommerce-store-1\",\"id\":\"ecommerce-store-1\",\"title\":\"Ecommerce Store Website Template\",\"pageTitle\":\"Ecommerce Store Website Template\",\"category\":\"Websites\",\"project_id\":\"a8e59680-e4fc-4735-a797-36af2f7e2875\",\"url\":\"https://linea-jewelry.lovable.app\",\"subtitle\":\"Launch a luxury jewelry store with editorial-grade product showcases and complete checkout flow. Professional design, mobile-optimized browsing, and premium brand presentation—go live in hours, not weeks.\",\"tagline\":\"Premium design for webstore\",\"description\":\"This template gives you a complete jewelry e-commerce store that looks professional and you don't need design skills to make it work.\",\"metaTitle\":\"Ecommerce Store Website Template | Online Shop Builder | Lovable\",\"metaDescription\":\"Launch a modern online store with this free ecommerce template. Clean product pages, cart functionality, and responsive design - ready to customise.\",\"subcategory\":\"ecommerce\",\"platform\":\"Web\",\"screenshot\":\"https://assets.lovable.dev/templates/ecommerce-store-1-screenshot.webp\",\"thumbnail\":\"https://assets.lovable.dev/templates/ecommerce-store-1-screenshot.webp\",\"previewScreenshot\":\"https://assets.lovable.dev/templates/ecommerce-store-1-screenshot.webp\",\"author\":{\"username\":\"Rickard Liljeros\",\"avatar\":\"https://lovable.dev/img/logo/lovable-icon-bg-light.png\"},\"shownOn\":[\"homepage\",\"dashboard-templates\",\"templates\"],\"is_partner_template\":true,\"date\":\"2025-12-01T10:00:00.000Z\",\"highlights\":[{\"icon\":\"cart\",\"title\":\"Launch-Ready Ecommerce Store\",\"description\":\"Complete e-commerce frontend with product galleries, checkout flow, and editorial storytelling for luxury brands\"},{\"icon\":\"image_stack\",\"title\":\"Editorial-Grade Product Showcases\",\"description\":\"Professional image galleries with zoom capabilities designed specifically for jewelry and luxury product photography\"},{\"icon\":\"color_palette\",\"title\":\"Premium Design System Included\",\"description\":\"40+ UI components with custom typography and color theming for sophisticated brand presentation\"},{\"icon\":\"phone_iphone\",\"title\":\"Mobile-First Luxury Experience\",\"description\":\"Responsive layouts optimized for viewing fine jewelry on any device with professional polish\"},{\"icon\":\"search\",\"title\":\"SEO-Optimized for Discovery\",\"description\":\"Pre-configured meta tags and structured data to help customers find your jewelry collection\"}],\"features\":[{\"title\":\"Complete Page Architecture\",\"description\":\"Homepage, category pages, product details, checkout, about sections, sustainability story, size guide, and customer care all included\"},{\"title\":\"Product Image Galleries\",\"description\":\"Interactive image galleries with zoom functionality showcase jewelry details, perfect for displaying craftsmanship and materials at scale\"},{\"title\":\"Flexible Content Sections\",\"description\":\"Hero banners, 50/50 splits, asymmetric layouts, and carousels enable editorial storytelling that elevates brand perception and prestige\"},{\"title\":\"Category Navigation System\",\"description\":\"Breadcrumb navigation, filter bars, sort options, and pagination create intuitive browsing experiences for jewelry collections and product lines\"},{\"title\":\"Product Detail Pages\",\"description\":\"Accordion-based descriptions, review sections, and detailed specifications present jewelry information professionally for confident purchasing decisions\"},{\"title\":\"Brand Story Pages\",\"description\":\"Dedicated about sections for brand story, sustainability commitments, and values communicate luxury positioning that justifies premium pricing\"},{\"title\":\"Shadcn UI Component Library\",\"description\":\"40+ pre-built components including forms, dialogs, cards, and dropdowns accelerate customization without compromising professional design standards\"},{\"title\":\"TypeScript and React Foundation\",\"description\":\"Modern tech stack with Vite build tool enables developers to extend functionality and add backend integrations as business grows\"},{\"title\":\"Tailwind CSS Design System\",\"description\":\"Custom design tokens and semantic color system with dark mode support allow brand customization while maintaining visual consistency\"},{\"title\":\"Store Locator Framework\",\"description\":\"Built-in store locator pages with map integration placeholders enable multi-location retailers to showcase physical presence and drive foot traffic\"},{\"title\":\"Privacy and Legal Pages\",\"description\":\"Pre-built privacy policy and terms of service pages establish trust and meet compliance requirements for e-commerce operations\"},{\"title\":\"Responsive Typography System\",\"description\":\"DM Sans font with fluid type scales ensures exceptional readability and luxury aesthetic across all screen sizes and devices\"}],\"content\":\"$54\",\"relativePath\":\"ecommerce-store-1.md\"}]}]]\n"])</script></body></html>